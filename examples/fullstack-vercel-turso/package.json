{
  "name": "example-fullstack-vercel-turso",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "docker compose up -d && react-router dev",
    "dev:app": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "biome lint --error-on-warnings .",
    "lint:fix": "biome lint --write .",
    "format": "prettier --experimental-cli --check .",
    "format:fix": "prettier --experimental-cli --write ."
  },
  "dependencies": {
    "@coji/durably": "workspace:*",
    "@coji/durably-react": "workspace:*",
    "@libsql/kysely-libsql": "^0.4.1",
    "@react-router/node": "7.13.2",
    "@react-router/serve": "7.13.2",
    "@vercel/react-router": "^1.2.6",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@react-router/dev": "7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
