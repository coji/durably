{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "react-router",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=example-fullstack-vercel-turso",
  "crons": [
    {
      "path": "/api/worker",
      "schedule": "0 0 * * *"
    }
  ]
}
