{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "react-router",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter example-fullstack-vercel-turso build",
  "crons": [
    {
      "path": "/api/worker",
      "schedule": "* * * * *"
    }
  ]
}
