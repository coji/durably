{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["TURSO_DATABASE_URL", "TURSO_AUTH_TOKEN"],
      "outputs": ["dist/**", "build/**", ".vitepress/dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:node": {
      "dependsOn": ["^build"]
    },
    "test:browser": {
      "dependsOn": ["^build"]
    },
    "test:react": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "format": {}
  }
}
